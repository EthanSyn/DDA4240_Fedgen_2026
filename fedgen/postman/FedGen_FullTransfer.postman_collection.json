            {
              "listen": "test",
              "script": {
                "id": "5f6e7b0d-faf0-4a21-8064-4d938a77959c",
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.endpoint) {",
                  "    pm.collectionVariables.set('EDR_ENDPOINT', jsonData.endpoint);",
                  "    console.log('EDR Endpoint:', jsonData.endpoint);",
                  "}",
                  "if (jsonData.authorization) {",
                  "    pm.collectionVariables.set('EDR_TOKEN', jsonData.authorization);",
                  "    console.log('Got authorization token');",
                  "}"
                ]
              }
            }
          ]
        },
